---
import BaseLayout from "../layouts/BaseLayout.astro";
import ChatWidget from "../components/ChatWidget";
import {
  about,
  experience,
  highlights,
  languages,
  profile,
  stack
} from "../data/site";
---

<BaseLayout
  title={`${profile.name} | ${profile.role}`}
  description={profile.intro.join(" ")}
>
  <div class="page-shell">
    <aside class="sidebar">
      <div class="sidebar__inner">
        <a class="brand" href="#top">{profile.name}</a>
        <p class="role">{profile.role}</p>
        <p class="location">{profile.location}</p>
        <p class="availability availability--sidebar">
          <span class="availability-dot" aria-hidden="true"></span>
          Open to work (Remote)
        </p>
        <div class="intro">
          {profile.intro.map((paragraph) => <p>{paragraph}</p>)}
        </div>

        <nav class="section-nav" aria-label="Primary">
          <a href="#about">About</a>
          <a href="#stack">Stack</a>
          <a href="#experience">Experience</a>
          <a href="#highlights">Highlights</a>
          <a href="#languages">Languages</a>
        </nav>

        <a class="sidebar-email" href={`mailto:${profile.email}`}>{profile.email}</a>

        <ul class="social-list" aria-label="Social links">
          {
            profile.social.map((item) => (
              <li>
                <a href={item.href} target="_blank" rel="noreferrer">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </aside>

    <main class="content" id="top">
      <section class="section" id="about">
        <span class="eyebrow">About</span>
        <div class="copy-stack">
          {about.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </section>

      <section class="section" id="stack">
        <span class="eyebrow">Stack</span>
        <div class="stack-grid">
          {
            stack.map((group) => (
              <article class="stack-card">
                <h2>{group.category}</h2>
                <ul class="tag-list">
                  {group.items.map((item) => <li>{item}</li>)}
                </ul>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" id="experience">
        <span class="eyebrow">Experience</span>
        <div class="card-stack">
          {
            experience.map((item) => (
              <article class="entry-card">
                <p class="meta">{item.period}</p>
                <div class="entry-card__body">
                  <h2>
                    {item.title} <span>@ {item.company}</span>
                  </h2>
                  <p>{item.description}</p>
                  <ul class="tag-list">
                    {item.tags.map((tag) => <li>{tag}</li>)}
                  </ul>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" id="highlights">
        <span class="eyebrow">Highlights</span>
        <div class="card-stack">
          {
            highlights.map((item) => (
              <article class="entry-card entry-card--link">
                <div class="entry-card__body">
                  <h2>{item.name}</h2>
                  <p>{item.description}</p>
                  <ul class="tag-list">
                    {item.tags.map((tag) => <li>{tag}</li>)}
                  </ul>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" id="languages">
        <span class="eyebrow">Languages</span>
        <div class="languages-list">
          {
            languages.map((language) => (
              <article class="language-row">
                <h2>{language.name}</h2>
                <p>{language.level}</p>
              </article>
            ))
          }
        </div>
      </section>

      <footer class="mobile-footer">
        <a class="mobile-footer__email" href={`mailto:${profile.email}`}>{profile.email}</a>
        <ul class="mobile-footer__socials" aria-label="Social links">
          {
            profile.social.map((item) => (
              <li>
                <a href={item.href} target="_blank" rel="noreferrer">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </footer>

    </main>
  </div>
  <ChatWidget client:load />
</BaseLayout>
