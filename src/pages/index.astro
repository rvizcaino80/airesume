---
import BaseLayout from "../layouts/BaseLayout.astro";
import ChatWidget from "../components/ChatWidget";
import { defaultLanguage, siteContent } from "../data/site";

const content = siteContent[defaultLanguage];
---

<BaseLayout
  title={content.meta.title}
  description={content.profile.intro.join(" ")}
>
  <div class="page-shell">
    <aside class="sidebar">
      <div class="sidebar__inner">
        <div class="language-switch" role="group" aria-label="Language switch">
          <button class="language-switch__button is-active" type="button" data-language-button data-language="en">
            English
          </button>
          <button class="language-switch__button" type="button" data-language-button data-language="es">
            Español
          </button>
        </div>

        <a class="brand" href="#top" data-profile-name>{content.profile.name}</a>
        <p class="role" data-profile-role>{content.profile.role}</p>
        <p class="availability availability--sidebar">
          <span class="availability-dot" aria-hidden="true"></span>
          <span data-label-availability>{content.labels.availability}</span>
        </p>
        <div class="intro" data-profile-intro>
          {content.profile.intro.map((paragraph) => <p>{paragraph}</p>)}
        </div>

        <nav class="section-nav" data-nav aria-label={content.labels.navAria}>
          <a href="#about" data-nav-about>{content.labels.about}</a>
          <a href="#stack" data-nav-stack>{content.labels.stack}</a>
          <a href="#experience" data-nav-experience>{content.labels.experience}</a>
          <a href="#languages" data-nav-languages>{content.labels.languages}</a>
        </nav>

        <a class="sidebar-email" href={`mailto:${content.profile.email}`} data-profile-email>
          {content.profile.email}
        </a>

        <ul class="social-list" aria-label={content.labels.socialAria} data-social-list>
          {
            content.profile.social.map((item) => (
              <li>
                <a href={item.href} target="_blank" rel="noreferrer">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>

        <button
          class="export-button relative z-[21] mt-5 w-fit cursor-pointer appearance-none rounded-full border border-amber-300 bg-amber-300 px-[0.88rem] py-[0.58rem] text-[0.9rem] font-semibold leading-none text-black transition hover:-translate-y-[1px] hover:border-amber-400 hover:bg-amber-400 focus-visible:-translate-y-[1px] focus-visible:border-amber-400 focus-visible:bg-amber-400 focus-visible:outline-none"
          type="button"
          data-export-resume
        >
          <span data-label-export>{content.labels.exportResume}</span>
        </button>
      </div>
    </aside>

    <main class="content" id="top">
      <section class="section" id="about">
        <span class="eyebrow eyebrow--about" data-label-about>{content.labels.about}</span>
        <div class="copy-stack" data-about>
          {content.about.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </section>

      <section class="section" id="stack">
        <span class="eyebrow eyebrow--stack" data-label-stack>{content.labels.stack}</span>
        <div class="stack-grid" data-stack>
          {
            content.stack.map((group) => (
              <article class="stack-card">
                <h2>{group.category}</h2>
                <ul class="tag-list">
                  {group.items.map((item) => <li>{item}</li>)}
                </ul>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" id="experience">
        <span class="eyebrow eyebrow--experience" data-label-experience>{content.labels.experience}</span>
        <div class="card-stack" data-experience>
          {
            content.experience.map((item) => (
              <article class="entry-card">
                <p class="meta">{item.period}</p>
                <div class="entry-card__body">
                  <h2>
                    {item.title} <span>@ {item.company}</span>
                  </h2>
                  <div class="entry-copy">
                    {item.description.split("\n\n").map((paragraph) => <p>{paragraph}</p>)}
                  </div>
                  <ul class="tag-list">
                    {item.tags.map((tag) => <li>{tag}</li>)}
                  </ul>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" id="languages">
        <span class="eyebrow eyebrow--languages" data-label-languages>{content.labels.languages}</span>
        <div class="languages-list" data-languages>
          {
            content.languages.map((language) => (
              <article class="language-row">
                <h2>{language.name}</h2>
                <p>{language.level}</p>
              </article>
            ))
          }
        </div>
      </section>

      <footer class="mobile-footer">
        <a class="mobile-footer__email" href={`mailto:${content.profile.email}`} data-mobile-email>
          {content.profile.email}
        </a>
        <ul class="mobile-footer__socials" aria-label={content.labels.socialAria} data-mobile-socials>
          {
            content.profile.social.map((item) => (
              <li>
                <a href={item.href} target="_blank" rel="noreferrer">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </footer>
    </main>
  </div>
  <ChatWidget client:load />
  <script is:inline define:vars={{ siteContent, defaultLanguage }}>
    const exportButton = document.querySelector("[data-export-resume]");
    const languageButtons = Array.from(document.querySelectorAll("[data-language-button]"));
    const languageSwitch = document.querySelector(".language-switch");
    const brand = document.querySelector("[data-profile-name]");
    const role = document.querySelector("[data-profile-role]");
    const availability = document.querySelector("[data-label-availability]");
    const intro = document.querySelector("[data-profile-intro]");
    const nav = document.querySelector("[data-nav]");
    const navAbout = document.querySelector("[data-nav-about]");
    const navStack = document.querySelector("[data-nav-stack]");
    const navExperience = document.querySelector("[data-nav-experience]");
    const navLanguages = document.querySelector("[data-nav-languages]");
    const email = document.querySelector("[data-profile-email]");
    const exportLabel = document.querySelector("[data-label-export]");
    const aboutLabel = document.querySelector("[data-label-about]");
    const stackLabel = document.querySelector("[data-label-stack]");
    const experienceLabel = document.querySelector("[data-label-experience]");
    const languagesLabel = document.querySelector("[data-label-languages]");
    const about = document.querySelector("[data-about]");
    const stack = document.querySelector("[data-stack]");
    const experience = document.querySelector("[data-experience]");
    const languages = document.querySelector("[data-languages]");
    const socialList = document.querySelector("[data-social-list]");
    const mobileEmail = document.querySelector("[data-mobile-email]");
    const mobileSocials = document.querySelector("[data-mobile-socials]");

    const renderParagraphs = (container, paragraphs) => {
      if (!container) return;
      container.innerHTML = paragraphs.map((paragraph) => `<p>${paragraph}</p>`).join("");
    };

    const renderTagList = (items) => `<ul class="tag-list">${items.map((item) => `<li>${item}</li>`).join("")}</ul>`;

    const renderSocials = (container, items) => {
      if (!container) return;
      container.innerHTML = items
        .map(
          (item) =>
            `<li><a href="${item.href}" target="_blank" rel="noreferrer">${item.label}</a></li>`
        )
        .join("");
    };

    const updateLanguageSwitchIndicator = (activeLanguage) => {
      if (!languageSwitch) return;

      const activeButton = languageButtons.find((button) => button.dataset.language === activeLanguage);

      if (!activeButton) return;

      languageSwitch.style.setProperty("--switch-pill-x", `${activeButton.offsetLeft}px`);
      languageSwitch.style.setProperty("--switch-pill-y", `${activeButton.offsetTop}px`);
      languageSwitch.style.setProperty("--switch-pill-w", `${activeButton.offsetWidth}px`);
      languageSwitch.style.setProperty("--switch-pill-h", `${activeButton.offsetHeight}px`);
    };

    const applyLanguage = (language) => {
      const next = siteContent[language] || siteContent[defaultLanguage];

      document.documentElement.lang = language === "es" ? "es" : "en";
      document.title = next.meta.title;

      brand.textContent = next.profile.name;
      role.textContent = next.profile.role;
      availability.textContent = next.labels.availability;
      renderParagraphs(intro, next.profile.intro);

      nav?.setAttribute("aria-label", next.labels.navAria);
      navAbout.textContent = next.labels.about;
      navStack.textContent = next.labels.stack;
      navExperience.textContent = next.labels.experience;
      navLanguages.textContent = next.labels.languages;

      email.textContent = next.profile.email;
      email.setAttribute("href", `mailto:${next.profile.email}`);
      mobileEmail.textContent = next.profile.email;
      mobileEmail.setAttribute("href", `mailto:${next.profile.email}`);

      socialList?.setAttribute("aria-label", next.labels.socialAria);
      mobileSocials?.setAttribute("aria-label", next.labels.socialAria);
      renderSocials(socialList, next.profile.social);
      renderSocials(mobileSocials, next.profile.social);

      exportLabel.textContent = next.labels.exportResume;
      aboutLabel.textContent = next.labels.about;
      stackLabel.textContent = next.labels.stack;
      experienceLabel.textContent = next.labels.experience;
      languagesLabel.textContent = next.labels.languages;

      renderParagraphs(about, next.about);

      stack.innerHTML = next.stack
        .map(
          (group) =>
            `<article class="stack-card"><h2>${group.category}</h2>${renderTagList(group.items)}</article>`
        )
        .join("");

      experience.innerHTML = next.experience
        .map((item) => {
          const paragraphs = item.description
            .split("\\n\\n")
            .map((paragraph) => `<p>${paragraph}</p>`)
            .join("");

          return `<article class="entry-card"><p class="meta">${item.period}</p><div class="entry-card__body"><h2>${item.title} <span>@ ${item.company}</span></h2><div class="entry-copy">${paragraphs}</div>${renderTagList(item.tags)}</div></article>`;
        })
        .join("");

      languages.innerHTML = next.languages
        .map(
          (languageItem) =>
            `<article class="language-row"><h2>${languageItem.name}</h2><p>${languageItem.level}</p></article>`
        )
        .join("");

      languageButtons.forEach((button) => {
        const isActive = button.dataset.language === language;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-pressed", isActive ? "true" : "false");
      });

      updateLanguageSwitchIndicator(language);
      localStorage.setItem("resume-language", language);
    };

    const initialLanguage = localStorage.getItem("resume-language") || defaultLanguage;
    applyLanguage(initialLanguage);

    window.addEventListener("resize", () => {
      const activeLanguage = languageButtons.find((button) => button.classList.contains("is-active"))?.dataset.language;
      updateLanguageSwitchIndicator(activeLanguage === "es" ? "es" : defaultLanguage);
    });

    languageButtons.forEach((button) => {
      button.addEventListener("click", () => {
        applyLanguage(button.dataset.language || defaultLanguage);
      });
    });

    exportButton?.addEventListener("click", () => {
      window.print();
    });
  </script>
</BaseLayout>
